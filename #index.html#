<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Student Form: Rising 10th Grade Lottery</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=Jost:ital,wght@0,100..900;1,100..900&display=swap');

    /* Light reset */
    *,
    *:before,
    *:after {
      box-sizing: border-box;
      padding: 0;
      margin: 0;
    }

    body {
      width: 40em;
      margin: 1in auto;
      font-size: 18px;
      font-family: "Atkinson Hyperlegible", sans-serif;
      background: #ddf;
    }

    h1 {
      margin-top: 0.5em;
    }

    h2 {
    }

    p {
      line-height: 1.5;
    }

    b.area {
      color: #444;
    }

    #instructions {
      text-align: left;
    }

    #whoami {
      margin: 0;
      text-align: right;
      font-size: 90%;
      color: grey;
    }

    #rankings {
      ul {
        margin-top: 0.5em;
        padding-inline-start: 2em;
        text-align: left;

        li {
          line-height: 2;
        }
      }
    }

    p.sibling {
      text-align: center;
      font-style: italic;
      font-size: 85%;
    }

    .widget {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 20px auto;
      padding: 20px;
      border: 1px solid #335;
      border-radius: 8px;
      text-align: center;
      background: #fff;

      p {
        margin: 0.5em 0;
      }

      &>div {
        font-size: 16px;
        padding: 0.5em;
        border: 1px solid #ddd;
        text-align: left;
      }
    }

    fieldset {
      border-radius: 4px;
      border: 1px solid #ddd;

      legend {
        font-weight: 900;
        padding: 0 1em;
      }

      p.empty-note {
        display: none;
        font-style: italic;
      }
    }

    .tiles {
      display: flex;
      flex-direction: row;
      justify-content: center;
      gap: 0.5em;
      list-style-type: none;
      padding: 1em;

      &>p {
        font-style: italic;
      }

      &>li {
        width: 18%;
        display: flex;
        flex-direction: column;
        gap: 3px;
        justify-content: space-around;

        .rank {
          font-size: 80%;
        }
      }

    }

    .draggable {
      background-color: #f9f9f9;
      border: 1px solid #ccc;
      padding: 10px;
      cursor: grab;
      border-radius: 4px;
      transition: background-color 0.2s;
    }

    .draggable:active {
      cursor: grabbing;
    }

    /* Visual cue for the item being moved */
    .draggable.dragging {
      opacity: 0.5;
      background-color: #e0e0e0;
    }

    #submit {
      margin-top: 10px;
      width: 100%;
      padding: 10px;
      border: none;
      border-radius: 4px;

      &:enabled {
        background-color: #007bff;
        color: white;
        cursor: pointer;
      }

      &:disabled {
        background-color: #ddd;
        color: black;
      }
    }

    #explanation {
      h2 {
        font-size: 14px;
      }
    }

    /* Spinner from https://loading.io/css/ */
    .lds-ellipsis,
    .lds-ellipsis div {
      box-sizing: border-box;
    }

    .lds-ellipsis {
      font-size: 32px;

      display: inline-block;
      position: relative;
      width: 1em;
      height: 0.16666em;
    }

    .lds-ellipsis div {
      position: absolute;
      top: 0;
      width: 0.16666em;
      height: 0.16666em;
      border-radius: 50%;
      background: currentColor;
      animation-timing-function: cubic-bezier(0, 1, 1, 0);
    }

    .lds-ellipsis div:nth-child(1) {
      left: 0.1em;
      animation: lds-ellipsis1 0.6s infinite;
    }

    .lds-ellipsis div:nth-child(2) {
      left: 0.1em;
      animation: lds-ellipsis2 0.6s infinite;
    }

    .lds-ellipsis div:nth-child(3) {
      left: 0.4em;
      animation: lds-ellipsis2 0.6s infinite;
    }

    .lds-ellipsis div:nth-child(4) {
      left: 0.7em;
      animation: lds-ellipsis3 0.6s infinite;
    }

    @keyframes lds-ellipsis1 {
      0% {
        transform: scale(0);
      }

      100% {
        transform: scale(1);
      }
    }

    @keyframes lds-ellipsis3 {
      0% {
        transform: scale(1);
      }

      100% {
        transform: scale(0);
      }
    }

    @keyframes lds-ellipsis2 {
      0% {
        transform: translate(0, 0);
      }

      100% {
        transform: translate(0.3em, 0);
      }
    }

    #for-student {
      display: none;

      &>div {
        display: flex;
        flex-direction: column;
        width: 100%;
        gap: 1em;
        padding: 1em;

        &>label {
          flex: 1;
          display: flex;
          gap: 0.5em;

          &>span {
            flex: 1;
          }

          &>input {
            flex: 3;
            padding: 3px;
          }
        }
      }
    }

    input:invalid {
      background: #fdd;
    }

    dialog {
      margin: auto;
      width: 30em;
      background: #ddf;
      padding: 2em;

      h1 {
        margin-top: 0;
      }

      &::backdrop {
        background-color: rgba(255,255,255,0.75);
      }
    }


  </style>
</head>

<body>

  <div class="widget">
    <dialog id="disabledDialog" closedby="none">
      <h1>Sorry, form is closed</h1>
      <p>
        If you want to change your LC lottery preferences, please talk to your counselor.
      </p>
    </dialog>

    <p id="whoami"></p>

    <h1 id="title">Student Form</h1>
    <h2 id="subtitle">Rising 10th Grade Lottery</h2>

    <fieldset id="for-student">
      <legend>Student</legend>
      <div>
        <label>
          <span>Student email:</span>
          <input type="text" id="student-email" pattern="\w+@students\.berkeley\.net" required>
        </label>
        <label>
         <span>BHS Student ID:</span>
          <input type="text" id="student-number" pattern="20\d{5}" required>
       </label>
      <label>
        <span>Reason:</span>
        <input type="text" id="student-reason" required placeholder="e.g. parent request">
      </label>
      </div>
    </fieldset>

    <section id="instructions">
      <p>
        <b>Step 1</b> Drag both LCs from the <b class="area">Must be ranked</b>
        area into the <b class="area">Currently ranked</b> area and put them in
        the order of your preference. You are required to rank both AC and BIHS.
      </p>
      <p>
        <b>Step 2</b> Drag any LC that you are interested in from
        the <b class="area">Unranked small schools</b> area into
        the <b class="area">Currently ranked</b> area to rank them. You are not
        required to rank any of the small LCs.
      </p>
      <p>
        <b>Step 3</b> Drag your LC choices in the <b class="area">Currently
        ranked</b> area into your preferred order from left to right. You may
        also drag out any small LC to remove it from your rankings. Once your
        choices are in your desired order, press the
        blue <b class="area">Save</b> button.
      </p>
    </section>

    <section id="upper-grade-instructions" style="display:none">
      <p>
        <b>Step 1</b> Drag any LCs from the <b class="area">Unranked LCs</b>
        area into the <b class="area">Currently ranked</b> area and put them in
        the order of your preference. Your current LC is already
        in <b class="area">Currently ranked</b> and can't be removed.
      </p>
      <p>
        <b>Step 2</b> Drag your LC choices in the <b class="area">Currently
        ranked</b> area into your preferred order from left to right. You may
        also drag out any LC other than your current LC to remove it from your
        rankings. Once your choices are in your desired order, press the
        blue <b class="area">Save</b> button.
      </p>
    </section>

    <fieldset>
      <legend>Must be ranked</legend>
      <ul class="tiles" id="mandatory">
        <li class="draggable" draggable="true" data-index="3"><span class="lc">AC</span></li>
        <li class="draggable" draggable="true" data-index="4"><span class="lc">BIHS</span></li>
      </ul>
    </fieldset>

    <fieldset>
      <legend>Currently ranked</legend>
      <ul class="tiles" id="ranks">
      </ul>
    </fieldset>

    <fieldset>
      <legend>Unranked small schools</legend>
      <ul class="tiles" id="small-schools">
        <li class="draggable" draggable="true" data-index="3"><span class="lc">AHA</span></li>
        <li class="draggable" draggable="true" data-index="4"><span class="lc">AMPS</span></li>
        <li class="draggable" draggable="true" data-index="5"><span class="lc">CAS</span></li>
      </ul>

      <p class="empty-note">
        All small LCs ranked. Remember, only rank small LCs that you are willing
        to be placed in. If you have ranked any small LCs that you would not
        want to be in, drag them out of the <b class="area">Currently ranked</b> area to unrank them.
      </p>
    </fieldset>

    <div class="explanation">
      <h2>Based on your current rankings ...</h2>
      <div id="rankings">
      </div>
    </div>

    <button type="button" id="submit" disabled>
      <div class="lds-ellipsis">
        <div></div>
        <div></div>
        <div></div>
        <div></div>
      </div>
    </button>
    <p class="sibling">If you have an older sibling who will be in your first choice LC next year, please <a
        href="https://forms.gle/wVMaxnWj8GrtF33r8" target="_blank">fill out this form</a>.</p>
  </div>
  <script>
    /*
 * Regexp to match a single HTML tag.
 */
const tagPattern = /^<(\w+)>$/;

/*
 * Get or create a single element. If the query is in the form of a tag, e.g.
 * '<p>' it creates an element of that type. Otherwise it queries the document
 * using the argument as a selector.
 */
const $ = (q, content) => {
  const tag = q.match(tagPattern)?.[1];
  if (tag) {
    const e = document.createElement(tag);
    if (content !== undefined) {
      e.append(content);
    }
    return e;
  } else {
    return document.querySelector(q);
  }
};

/*
 * Get all elements matching selector.
 */
const $$ = q => document.querySelectorAll(q);

/*
 * Create a text node.
 */
const text = t => document.createTextNode(t);

/*
 * Create an element or elements from literal HTML. If the HTML specifies just
 * one element it is returned. Otherwise returns an array of elements.
 */
const html = html => {
  const t = document.createElement('template');
  t.innerHTML = html.trim();
  const children = [...t.content.children];
  return children.length === 1 ? children[0] : children;
};

/*
 * Get an object containing all DOM objects with an id.
 */
const byId = () => Object.fromEntries([...document.querySelectorAll('[id]')].map(e => [e.id, e]));

/*
 * Decorate a DOM element with a CSS class.
 */
const withClass = (className, e) => {
  e.className = className;
  return e;
};

/*
 * Make an A element with a give text and href and an optional target.
 */
const a = (text, href, target) => {
  const e = $('<a>', text);
  e.setAttribute('href', href);
  if (target) {
    e.setAttribute('target', target);
  }
  return e;
};

/*
 * Make a named Bootstrap icon.
 */
const icon = name => {
  const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  const use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
  svg.classList.add('bi');
  use.setAttributeNS(
    'http://www.w3.org/1999/xlink',
    'xlink:href',
    `/img/bootstrap-icons.svg#${name}`,
  );
  svg.append(use);
  return svg;
};

const DEBUG = true;

let isStaff = false;
let isUpperGrade = false;
let assignedLc = null;

const REQUIRED = [ 'AC', 'BIHS' ];
const SLCS = new Set(['AHA', 'AMPS', 'CAS']);

// Months are zero-indexed in Date.
const FORM_CLOSES = new Date(2026, 3, 19, 12 + 4, 0, 0);

const mandatory = $('#mandatory');
const ranks = $('#ranks');
const smallSchools = $('#small-schools');
const draggables = $$('.draggable');
const button = $('#submit');
const spinner = button.querySelector('div.lds-ellipsis');

const lcName = (e) => e.querySelector('.lc').innerText;

const isClosed = () => new Date() > FORM_CLOSES;

const ensureRank = (e, rank) => {
  const r = e.querySelector('.rank');
  if (r) {
    r.innerText = `${rank}`;
  } else {
    e.prepend(withClass('rank', $('<span>', `${rank}`)));
  }
};

const clearRank = (e) => {
  e.querySelector('.rank')?.remove();
};

const explainRankings = () => {
  const ranked = [...$('#ranks').querySelectorAll('.draggable')].map(lcName);
  const e = $('#rankings');

  e.replaceChildren();
  const ul = $('<ul>');
  for (let i = 0; i < ranked.length; i++) {
    if (i == 0) {
      ul.append($('<li>', `If we can, we will place you in ${ranked[i]}.`));
    } else if (i < ranked.length - 1) {
      ul.append($('<li>', `If you can't be placed in ${listify(ranked.slice(0, i))}, we will try to place you in ${ranked[i]}.`));
    } else {
      const verb = (assignedLc && ranked[i] === assignedLc) ? 'remain in' : 'be placed in';
      ul.append($('<li>', `If you can't be placed in ${listify(ranked.slice(0, i))}, you will ${verb} ${ranked[i]}.`));
    }
  }
  e.append(ul);

  maybeShowEmptyNote();
}

const getRanks = () => {
  return [...$('#ranks').querySelectorAll('.draggable')].map(lcName);
};

const listify = (items) => {
  if (items.length === 1) {
    return items[0];
  } else if (items.length === 2) {
    return items.join(' or ');
  } else {
    return `${items.slice(0, items.length - 1).join(', ')}, or ${items[items.length - 1]}`;
  }
};

const getClosest = (draggables, x) => {
  const initial = { dist: Number.POSITIVE_INFINITY };
  return draggables.reduce((soFar, e) => {
    const dist = Math.abs(x - centerOf(e));
    return dist < soFar.dist ? { dist, e } : soFar;
  }, initial).e;
};

const centerOf = (e) => {
  const box = e.getBoundingClientRect();
  return box.left + box.width / 2;
};

const maybeEnableButton = () => {
  //if (isClosed()) return;
  if (!mandatoryRanked()) {
    disableButton('Must rank AC and BIHS');
  } else if (isStaff && !staffFieldsValid()) {
    disableButton('Fill on-behalf-of information');
  } else {
    enableButton('Save');
  }
};

const staffFieldsValid = () => [...$$('#for-student input')].every(i => i.validity.valid);

const mandatoryRanked = () => {
  if (isUpperGrade) return ranks.children.length > 0;
  const ranked = new Set([...ranks.children].map(lcName));
  return REQUIRED.every(a => ranked.has(a));
}

const enableButton = (text) => {
  button.disabled = false;
  button.innerText = text;
}

const disableButton = (text) => {
  button.disabled = true;
  button.innerText = text;
};

const updateRankNumbers = () => {
  [...ranks.children].forEach((r, i) =>  {
    ensureRank(r, i + 1);
  });
  maybeEnableButton();
};

const maybeShowEmptyNote = () => {
  if (smallSchools.children.length === 0) {
    smallSchools.style.display = 'none';
    smallSchools.parentNode.querySelector('p').style.display = 'block';
  }
};

const maybeRemoveMandatory = () => {
  if (mandatory.children.length == 0) mandatory.parentNode.remove();
};

const makeTile = (name, pos) => {
  const li = withClass('draggable', $('<li>'));
  li.setAttribute('draggable', 'true');
  makeDraggable(li);
  li.dataset.index = `${pos}`;
  //li.append(withClass('rank', $('<span>', `${pos}`)));
  li.append(withClass('lc', $('<span>', name)));
  return li;
}


const showCurrentRanks = (currentRanks) => {
  const allTiles = Object.fromEntries([...$$('.tiles .draggable')].map(e => [ lcName(e), e]));
  REQUIRED.forEach((name, i) => {
    if (!(name in allTiles)) {
      allTiles[name] = makeTile(name, i + 1);
    }
  });
  const inOrder = currentRanks.map(name => allTiles[name]);
  ranks.replaceChildren();
  inOrder.forEach((e, i) => {
    ensureRank(e, i + 1);
    ranks.append(e);
  });
  explainRankings();
  maybeRemoveMandatory();
};

const getRankings = (studentEmail) => {
  google.script.run.withSuccessHandler(res => {
    res = JSON.parse(res);
    if (res.rankings) {
      showCurrentRanks(res.rankings);
    }
    disableButton('Rankings loaded');
  }).getRankings(studentEmail);
};

const makeDraggable = (draggable) => {
 draggable.ondragstart = () => {
    draggable.classList.add('dragging');
  };

  draggable.ondragend = () => {
    draggable.classList.remove('dragging');
    explainRankings();
  };
};

draggables.forEach(makeDraggable);

// Handle the dragging to new position
ranks.ondragover = (e) => {

  const inRanks = [...ranks.querySelectorAll('.draggable')];

  e.stopPropagation()
  e.preventDefault(); // Everything can be dropped here

  const dragging = $('.dragging');

  if (inRanks.length === 0) {
    ranks.append(dragging);
    finishDrop();

  } else {
    const closest = getClosest(inRanks, e.clientX);
    if (closest !== dragging) {
      let where = null;
      if (dragging.parentNode !== ranks) {
        if (closest === inRanks[inRanks.length - 1]) {
          where = closest.nextSibling;
        } else {
          where = closest;
        }
      } else {
        where = e.clientX < centerOf(closest) ? closest.nextSibling : closest;
      }
      ranks.insertBefore(dragging, where);
      finishDrop();
    }
  }

};

const finishDrop = () => {
  updateRankNumbers();
  maybeShowEmptyNote();
  maybeRemoveMandatory();
};

document.body.ondragover = (e) => {
  const dragging = $('.dragging');

  if (SLCS.has(lcName(dragging))) {
    e.preventDefault(); // allows dropping
    clearRank(dragging);
    updateRankNumbers();
    smallSchools.append(dragging)
    smallSchools.style.display = 'flex';
    smallSchools.parentNode.querySelector('p').style.display = 'none';
  }
};

button.onclick = () => {
  //if (isClosed()) return;
  const data = {
    ranks: getRanks(),
    studentEmail: $('#student-email')?.value,
    studentNumber: $('#student-number')?.value,
    reason: $('#student-reason')?.value,
  };
  button.replaceChildren(spinner);
  google.script.run
      .withSuccessHandler(res => {
        disableButton('Saved');
      })
      .saveRankings(data);
};

// Fetch any existing student rankings when staff member fills in email
$('#student-email').addEventListener('change', (e) => {
  getRankings(e.currentTarget.value);
});

// Keep button state up to date.
$('#for-student').addEventListener('change', (e) => {
  maybeEnableButton();
});

const setTitle = (heading, subtitle) => {
  $('title').innerText = `${heading}: ${subtitle}`;
  $('#title').innerText = heading;
  $('#subtitle').innerText = subtitle;
};

const setupUI = (res) => {
  $('#whoami').innerText = res;
  if (res.match(/@berkeley\.net/)) {
    isStaff = true;
    $('#for-student').style.display = 'flex';
    disableButton('Enter student email to start');
    setTitle('Adult Form', 'On behalf of a student for Rising 10th Grade Lottery');
  } else if (res.match(/@students\.berkeley\.net/)) {
    isStaff = false;
    $('#for-student').remove();
    if (isClosed()) {
      $('#disabledDialog').showModal();
    }
    google.script.run.withSuccessHandler(lc => {
      if (lc) {
        isUpperGrade = true;
        initFromUpperGrades(lc);
      }
      getRankings();
    }).getLcForStudent(res);
  }
};

const DEBUG_USERS = new Set(['peterseibel@berkeley.net']);

if (DEBUG) {
  google.script.run.withSuccessHandler(realEmail => {
    if (!DEBUG_USERS.has(realEmail)) {
      setupUI(realEmail);
      return;
    }
    const storedEmail = sessionStorage.getItem('debugEmail') || '';
    const bar = html(`<div style="position:fixed;top:0;left:0;right:0;background:#ff9;padding:6px 12px;font-size:14px;display:flex;gap:8px;align-items:center;z-index:999;border-bottom:1px solid #a90">
      <b>DEBUG</b>
      <input id="debug-email" type="text" value="${storedEmail}" placeholder="Enter email to simulate..." style="flex:1;padding:3px">
    </div>`);
    document.body.prepend(bar);
    document.body.style.paddingTop = '36px';
    const applyDebugEmail = () => {
      sessionStorage.setItem('debugEmail', $('#debug-email').value);
      location.reload();
    };
    $('#debug-email').addEventListener('change', applyDebugEmail);
    $('#debug-email').addEventListener('keydown', e => {
      if (e.key === 'Enter') applyDebugEmail();
    });
    setupUI(storedEmail || realEmail);
  }).whoami();
} else {
  google.script.run.withSuccessHandler(setupUI).whoami();
}

const initFromUpperGrades = (lc) => {
  assignedLc = lc;
  setTitle('Student Form', 'Upper Grades Lottery');
  $('#instructions').style.display = 'none';
  $('#upper-grade-instructions').style.display = 'block';
  smallSchools.closest('fieldset').querySelector('legend').innerText = 'Unranked LCs';
  const allTiles = [...$$('.tiles .draggable')];
  ranks.replaceChildren();
  smallSchools.replaceChildren();
  allTiles.forEach(tile => {
    if (lcName(tile) === assignedLc) {
      ensureRank(tile, 1);
      ranks.append(tile);
    } else {
      clearRank(tile);
      smallSchools.append(tile);
    }
  });
  if (mandatory.children.length === 0) mandatory.parentNode.remove();
  REQUIRED.forEach(r => SLCS.add(r));
  explainRankings();
  maybeEnableButton();
};


  </script>
</body>

</html>
